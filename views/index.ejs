<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FashionPlatform — Yeni Sezon</title>
  <meta name="description" content="FashionPlatform — sezonun öne çıkan parçaları ve özenle seçilmiş koleksiyonlar." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">FASHION<span>PLATFORM</span></a>
      <nav class="main-nav">
        <% categories.forEach(function (c) { %>
          <a href="#products" class="nav-link"><%= c.name %></a>
        <% }); %>
      </nav>
      <div class="header-actions">
        <button class="icon-btn" aria-label="Ara">⌕</button>
        <button class="icon-btn" aria-label="Sepet">⛶</button>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <p class="eyebrow"><%= hero.eyebrow %></p>
        <h1 class="hero-title"><%= hero.title %></h1>
        <p class="hero-subtitle"><%= hero.subtitle %></p>
        <a href="<%= hero.ctaHref %>" class="btn btn-primary"><%= hero.ctaLabel %></a>
      </div>
    </section>

    <!-- Categories -->
    <section class="categories">
      <div class="container">
        <div class="category-grid">
          <% categories.forEach(function (c) { %>
            <a href="#products" class="category-card">
              <span class="category-name"><%= c.name %></span>
              <span class="category-arrow">→</span>
            </a>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- Featured products -->
    <section id="products" class="products">
      <div class="container">
        <div class="section-head">
          <h2>Öne Çıkanlar</h2>
          <p>Sezonun en çok tercih edilen parçaları</p>
        </div>
        <div class="product-grid">
          <% products.forEach(function (p) { %>
            <article class="product-card">
              <div class="product-image" aria-hidden="true">
                <span class="product-image-label"><%= p.category %></span>
              </div>
              <div class="product-body">
                <span class="product-cat"><%= p.category %></span>
                <h3 class="product-name"><%= p.name %></h3>
                <p class="product-price"><%= p.currency %><%= p.price.toLocaleString('tr-TR') %></p>
              </div>
            </article>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section id="newsletter" class="newsletter">
      <div class="container newsletter-inner">
        <h2>Yeniliklerden ilk sen haberdar ol</h2>
        <p>Yeni koleksiyonlar ve özel kampanyalar için bültenimize katıl.</p>
        <% if (typeof subscribed !== 'undefined' && subscribed) { %>
          <p class="newsletter-success">Teşekkürler! Aboneliğin alındı. ✓</p>
        <% } else { %>
          <form class="newsletter-form" action="/newsletter" method="post">
            <input type="email" name="email" placeholder="E-posta adresin" required />
            <button type="submit" class="btn btn-dark">Abone Ol</button>
          </form>
        <% } %>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <span class="logo logo-sm">FASHION<span>PLATFORM</span></span>
      <p>&copy; <%= year %> FashionPlatform. Tüm hakları saklıdır.</p>
    </div>
  </footer>
</body>
</html>
