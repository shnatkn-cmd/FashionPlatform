# ----------------------------------------------------------------------------
# FashionPlatform environment configuration
# Copy this file to ".env" and fill in the real values.
# DO NOT commit the real .env file (it is git-ignored).
# ----------------------------------------------------------------------------

# App
PORT=3000
NODE_ENV=development

# ----------------------------------------------------------------------------
# Hostinger MySQL database
# (these values will be provided by Hostinger -> Databases -> Management)
# ----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10
